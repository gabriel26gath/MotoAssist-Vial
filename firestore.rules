rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Funciones de validación globales duras
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "admin@acsa.com";
    }

    function isViewer() {
      return isSignedIn() && (
        request.auth.token.email == "moto@acsa.com" || 
        request.auth.token.email == "admin@acsa.com"
      );
    }

    function isValidInvoice(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.issuer is string && data.issuer.size() <= 256 &&
             data.date is string && data.date.size() <= 64 &&
             data.invoiceNumber is string && data.invoiceNumber.size() <= 128 &&
             data.total is number &&
             data.tax is number &&
             data.paymentMethod is string && data.paymentMethod.size() <= 128 &&
             data.imageUrl is string &&
             data.createdAt is string;
    }

    function isValidMotorizado(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.vehiclePlate is string && data.vehiclePlate.size() <= 32 &&
             data.status is string && (data.status == "activo" || data.status == "inactivo") &&
             data.createdAt is string;
    }

    function isValidIncident(data) {
      return data.motorizadoId is string && data.motorizadoId.size() <= 128 &&
             data.date is string && data.date.size() <= 64 &&
             data.description is string && data.description.size() <= 1024 &&
             data.severity is string && (data.severity == "baja" || data.severity == "media" || data.severity == "alta") &&
             data.status is string && (data.status == "pendiente" || data.status == "resuelto");
    }

    // Reglas para la colección de facturas térmicas
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isViewer() && isValidInvoice(request.resource.data);
      allow update: if isSignedIn() && isViewer() && isValidInvoice(request.resource.data);
      allow delete: if isSignedIn() && isAdmin();
    }

    // Reglas para la colección de fleet motorizados
    match /motorizados/{motorizadoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isViewer() && isValidMotorizado(request.resource.data);
      allow update: if isSignedIn() && isViewer() && isValidMotorizado(request.resource.data);
      allow delete: if isSignedIn() && isAdmin();
    }

    // Reglas para la colección de incidentes
    match /incidents/{incidentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isViewer() && isValidIncident(request.resource.data);
      allow update: if isSignedIn() && isViewer() && isValidIncident(request.resource.data);
      allow delete: if isSignedIn() && isAdmin();
    }
  }
}
